<h1><%= @place["name"] %></h1>

<h2>My Entries</h2>

<% if @current_user %>
  <p>
    <a class="btn btn-primary" href="/entries/new?place_id=<%= @place["id"] %>">New Entry</a>
  </p>
<% end %>

<div class="row">
  <% for entry in @entries %>
    <div class="col-12 col-md-4">
      <h3><%= entry["title"] %></h3>
      <h4><%= entry["occurred_on"] %></h4>
      <p><%= entry["description"] %></p>
    </div>
  <% end %>
</div>

<p>
  <a class="btn btn-secondary" href="/places">Back to All Places</a>
</p>